# Credenciales de Firebase (copiar este archivo a .env y completar)
# Se obtienen en: Consola de Firebase > Configuracion del proyecto > Tus apps > SDK de Firebase
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=

# Credenciales del usuario administrador para el script de seed
# (node scripts/seed_firestore.mjs). Si la cuenta no existe, el seed la crea.
SEED_EMAIL=
SEED_PASSWORD=
